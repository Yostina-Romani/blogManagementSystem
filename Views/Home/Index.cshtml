@model BlogManagementSystem.ViewModels.HomeVM

@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background: #f5f7fb;
    }

    .post-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

    .post-card:hover {
        transform: translateY(-3px);
    }

    .btn-custom {
        border-radius: 20px;
        padding: 5px 12px;
        font-size: 13px;
    }

    .btn-download {
        background: #ff4d4d;
        color: white;
    }

    .btn-edit {
        background: #ffc107;
        color: black;
    }

    .btn-delete {
        background: #343a40;
        color: white;
    }

    .btn-comment {
        background: #0d6efd;
        color: white;
        border-radius: 20px;
    }

    .read-more {
        color: #0d6efd;
        cursor: pointer;
        font-weight: bold;
        font-size: 14px;
    }

    .search-box {
        border-radius: 25px;
        padding: 10px;
    }

</style>

<div class="container mt-4">

    <h2 class="mb-4 fw-bold">📌 Posts</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <!-- Search -->
    <form method="get" asp-action="Index" asp-controller="Home"
          class="d-flex gap-2 mb-4">

        <input type="text"
               name="search"
               class="form-control search-box"
               placeholder="Search posts..." />

        <button type="submit" class="btn btn-primary rounded-pill px-4">
            Search
        </button>
    </form>

    <!-- Posts -->
    @foreach (var post in Model.posts)
    {
        <div class="card post-card mb-4">

            <div class="card-body">

                <!-- Title -->
                <h4 class="fw-bold">
                    <a asp-action="Details"
                       asp-controller="Posts"
                       asp-route-postiD="@post.postsId"
                       class="text-decoration-none text-dark">
                        @post.Title
                    </a>
                </h4>

                <!-- Content -->
                <p id="content-@post.postsId"
                   class="text-muted"
                   style="max-height: 80px; overflow: hidden;">
                    @post.postContent
                </p>

                <span class="read-more"
                      onclick="toggleContent(@post.postsId)">
                    Read more
                </span>

                <!-- Date -->
                <div class="mt-2">
                    <small class="text-secondary">
                        @post.createAt
                    </small>
                </div>

                <!-- Image -->
                @if (!string.IsNullOrEmpty(post.imageUrl))
                {
                    <img src="@post.imageUrl"
                         class="img-fluid rounded mt-3"
                         style="max-height:250px;" />
                }

                <!-- Buttons -->
                <div class="mt-3 d-flex flex-wrap gap-2">

                    <a asp-action="ExportOnePost"
                       asp-controller="Posts"
                       asp-route-postId="@post.postsId"
                       class="btn btn-custom btn-download">
                        Download
                    </a>

                    <a asp-controller="Posts"
                       asp-action="Edit"
                       asp-route-postsId="@post.postsId"
                       class="btn btn-custom btn-edit">
                        Edit
                    </a>

                    <a asp-controller="Posts"
                       asp-action="DeletePost"
                       asp-route-postsId="@post.postsId"
                       class="btn btn-custom btn-delete">
                        Delete
                    </a>

                </div>

                <!-- Comments Button -->
                <button class="btn btn-comment mt-3"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#comments-@post.postsId">
                    💬 Comments (@(post.comments?.Count() ?? 0))
                </button>

                <!-- Comments -->
                <div class="collapse mt-3" id="comments-@post.postsId">

                    @if (post.comments != null && post.comments.Any())
                    {
                        foreach (var comment in post.comments)
                        {
                            <div class="border rounded p-2 mb-2 bg-light">

                                <p class="mb-1">
                                    @comment.commentContent
                                </p>

                                <div class="d-flex gap-2">

                                    <a asp-controller="Comments"
                                       asp-action="EditComment"
                                       asp-route-commentId="@comment.commentId"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-controller="Comments"
                                       asp-action="Delete_comment"
                                       asp-route-commentId="@comment.commentId"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No comments yet.</p>
                    }

                    <!-- Add Comment -->
                    <form method="post"
                          asp-controller="Comments"
                          asp-action="Index"
                          class="d-flex gap-2 mt-3">

                        <input type="hidden" name="postsId" value="@post.postsId" />

                        <input type="text"
                               name="commentContent"
                               class="form-control"
                               placeholder="Write a comment..." />

                        <button class="btn btn-success rounded-pill">
                            Add
                        </button>

                    </form>

                </div>

            </div>
        </div>
    }

    <!-- Export All -->
    <div class="text-center mt-4">
        <a asp-action="ExportAllToPdf"
           asp-controller="Posts"
           class="btn btn-danger px-4 rounded-pill">
            Download All PDF
        </a>
    </div>

</div>

<!-- JS Read More -->
<script>
    function toggleContent(id) {
        var el = document.getElementById("content-" + id);

        if (el.style.maxHeight === "80px") {
            el.style.maxHeight = "none";
        } else {
            el.style.maxHeight = "80px";
        }
    }
</script>