@using System.Security.Claims;
@model BlogManagementSystem.ViewModels.HomeVM

@{
    ViewData["Title"] = "Home Page";
}

<style>

    body {
        background: #f4f6fb;
    }

    .post-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
        padding: 10px;
    }

        .post-card:hover {
            transform: translateY(-5px);
        }

    .post-content {
        font-size: 15px;
        color: #555;
        line-height: 1.7;
        max-height: 90px;
        overflow: hidden;
        transition: max-height 0.4s ease;
    }

        .post-content.expanded {
            max-height: 1000px;
        }

    .read-more-btn {
        border: none;
        background: none;
        color: #0d6efd;
        font-weight: bold;
        cursor: pointer;
        font-size: 14px;
        padding: 0;
    }

        .read-more-btn:hover {
            text-decoration: underline;
        }

    .post-image {
        max-height: 300px;
        width: 100%;
        object-fit: cover;
        border-radius: 12px;
        margin-top: 10px;
    }

    .comment-box {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 8px;
        margin-bottom: 8px;
    }

</style>

<div class="container mt-4">

    <h2 class="mb-4 fw-bold">📌 Posts</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <!-- Search -->
    <form method="get" asp-action="Index" asp-controller="Home"
          class="d-flex gap-2 mb-4">

        <input type="text"
               name="search"
               class="form-control rounded-pill"
               placeholder="Search posts..." />

        <button type="submit" class="btn btn-primary rounded-pill px-4">
            Search
        </button>
    </form>

    <!-- POSTS -->
    @foreach (var post in Model.posts)
    {
        <div class="card post-card mb-4">

            <div class="card-body">

                <!-- Title -->
                <h4 class="fw-bold">
                    <a asp-action="Details"
                       asp-controller="Posts"
                       asp-route-postiD="@post.postsId"
                       class="text-decoration-none text-dark">
                        @post.Title
                    </a>
                </h4>

                <!-- Content -->
                <p id="content-@post.postsId"
                   class="post-content">
                    @post.postContent
                </p>

                <button id="btn-@post.postsId"
                        class="read-more-btn"
                        onclick="toggleContent(@post.postsId)">
                    Read more
                </button>

                <!-- Date -->
                <div class="mt-2">
                    <small class="text-secondary">
                        @post.createAt
                    </small>
                </div>

                <!-- Image -->
                @if (!string.IsNullOrEmpty(post.imageUrl))
                {
                    <img src="@post.imageUrl"
                         class="post-image" />
                }

                <!-- Buttons -->
                <div class="mt-3 d-flex gap-2">

                    <a asp-action="ExportOnePost"
                       asp-controller="Posts"
                       asp-route-postId="@post.postsId"
                       class="btn btn-danger btn-sm">
                        Download
                    </a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        var claim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                        bool isAdmin = User.IsInRole("Admin");
                        int.TryParse(claim, out int userId);
                        
                            if (post.userId == userId||isAdmin)
                            {
                                <a asp-action="Edit"
                                   asp-controller="Posts"
                                   asp-route-postsId="@post.postsId"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="DeletePost"
                                   asp-controller="Posts"
                                   asp-route-postsId="@post.postsId"
                                   class="btn btn-dark btn-sm">
                                    Delete
                                </a>
                            }
                        
                    }
                </div>

                <!-- COMMENTS -->
                <button class="btn btn-primary mt-3"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#comments-@post.postsId">
                    💬 Comments (@(post.comments?.Count() ?? 0))
                </button>

                <div class="collapse mt-3" id="comments-@post.postsId">

                    @if (post.comments != null && post.comments.Any())
                    {
                        foreach (var comment in post.comments)
                        {
                            <div class="comment-box">

                                <p class="mb-1">
                                    @comment.commentContent
                                </p>
                                <div class="mt-2">
                                    <small class="text-secondary">
                                        @comment.commentTime
                                    </small>
                                </div>
                                <p class="mb-1">
                                    @comment.user?.UserName
                                </p>

                                <div class="d-flex gap-2">
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        bool isAdmin = User.IsInRole("Admin");
                                        var user_id = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                                         int.TryParse(user_id, out int UserId1);
                                        
                                            if (UserId1 == comment.usersId||isAdmin)
                                            {

                                                <a asp-controller="Comments"
                                                asp-action="EditComment"
                                                asp-route-commentId="@comment.commentId"
                                                class="btn btn-sm btn-outline-primary">
                                                    Edit
                                                </a>

                                                <a asp-controller="Comments"
                                                asp-action="Delete_comment"
                                                asp-route-commentId="@comment.commentId"
                                                class="btn btn-sm btn-outline-danger">
                                                    Delete
                                                </a>
                                            }
                                        
                                    }
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No comments yet.</p>
                    }

                    <!-- Add Comment -->
                    <form method="post"
                          asp-controller="Comments"
                          asp-action="Index"
                          class="d-flex gap-2 mt-3">

                        <input type="hidden" name="postsId" value="@post.postsId" />

                        <input type="text"
                               name="commentContent"
                               class="form-control"
                               placeholder="Write a comment..." />

                        <button class="btn btn-success">
                            Add
                        </button>

                    </form>

                </div>

            </div>
        </div>
    }

    <!-- Export All -->
    <div class="text-center mt-4">
        <a asp-action="ExportAllToPdf"
           asp-controller="Posts"
           class="btn btn-danger px-4 rounded-pill">
            Download All PDF
        </a>
    </div>

</div>

<!-- JS -->
<script>

    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".post-content").forEach(function (el) {

            let id = el.id.split("-")[1];
            let btn = document.getElementById("btn-" + id);

            if (el.scrollHeight <= 90) {
                btn.style.display = "none";
            }

        });

    });

    function toggleContent(id) {

        let content = document.getElementById("content-" + id);
        let btn = document.getElementById("btn-" + id);

        content.classList.toggle("expanded");

        if (content.classList.contains("expanded")) {
            btn.innerText = "Show less";
        } else {
            btn.innerText = "Read more";
        }
    }

</script>