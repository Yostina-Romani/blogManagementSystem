@model Comments

<style>

    body {
        background: #f4f6fb;
    }

    .delete-comment-box {
        max-width: 450px;
        margin: 80px auto;
        background: white;
        padding: 30px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        text-align: center;
    }

    .warning-icon {
        font-size: 45px;
        margin-bottom: 10px;
    }

    .delete-title {
        font-size: 24px;
        font-weight: bold;
        color: #dc3545;
        margin-bottom: 10px;
    }

    .delete-text {
        color: #666;
        margin-bottom: 25px;
        font-size: 15px;
    }

    .btn-delete {
        border: none;
        background: #dc3545;
        color: white;
        padding: 10px 18px;
        border-radius: 25px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-delete:hover {
            background: #bb2d3b;
        }

    .btn-cancel {
        display: inline-block;
        margin-left: 10px;
        background: #6c757d;
        color: white;
        padding: 10px 18px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            background: #5a6268;
            color: white;
        }

</style>

<div class="delete-comment-box">

    <div class="warning-icon">
        ⚠️
    </div>

    <div class="delete-title">
        Delete Comment
    </div>

    <div class="delete-text">
        Are you sure you want to delete this comment?
        This action cannot be undone.
    </div>

    <form method="post"
          asp-action="Delete_comment"
          asp-controller="Comments">

        <input type="hidden" asp-for="commentId" />

        <button type="submit" class="btn-delete">
            Yes, Delete
        </button>

        <a asp-action="Index"
           asp-controller="Home"
           class="btn-cancel">
            Cancel
        </a>

    </form>

</div>