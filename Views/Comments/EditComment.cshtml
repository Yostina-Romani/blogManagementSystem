@model Comments

<style>

    body {
        background: #f4f6fb;
    }

    .comment-edit-box {
        max-width: 550px;
        margin: 70px auto;
        background: white;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .edit-title {
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
    }

    textarea {
        width: 100%;
        height: 140px;
        resize: none;
        border-radius: 12px;
        border: 1px solid #ddd;
        padding: 12px;
        font-size: 15px;
        transition: 0.3s;
    }

        textarea:focus {
            border-color: #0d6efd;
            outline: none;
            box-shadow: 0 0 0 4px rgba(13,110,253,0.15);
        }

    .btn-save {
        width: 100%;
        margin-top: 18px;
        border: none;
        background: #0d6efd;
        color: white;
        padding: 12px;
        border-radius: 25px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-save:hover {
            background: #0b5ed7;
        }

    .alert-custom {
        background: #ffe5e5;
        color: #dc3545;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 15px;
        text-align: center;
    }

</style>

<div class="comment-edit-box">

    <h2 class="edit-title">
        ✏️ Edit Comment
    </h2>

    @if (TempData["error"] != null)
    {
        <div class="alert-custom">
            @TempData["error"]
        </div>
    }

    <form method="post">

        <input type="hidden" asp-for="commentId" />

        <textarea asp-for="commentContent"
                  placeholder="Edit your comment..."></textarea>

        <button type="submit" class="btn-save">
            Save Changes
        </button>

    </form>

</div>