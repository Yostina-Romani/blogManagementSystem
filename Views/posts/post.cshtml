@model Posts

<!DOCTYPE html>
<html>
<head>
    <title>Create Post</title>

    <!-- ممكن تضيف Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f5f7fa;
        }

        .post-container {
            max-width: 600px;
            margin: 60px auto;
            padding: 30px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .post-title {
            text-align: center;
            margin-bottom: 25px;
            font-weight: bold;
        }

        .form-control {
            border-radius: 8px;
        }

        textarea {
            resize: none;
            height: 150px;
        }

        .btn-post {
            width: 100%;
            border-radius: 8px;
            padding: 10px;
            font-weight: bold;
        }

        .file-input {
            padding: 6px;
        }
    </style>
</head>

<body>

    <div class="post-container">
        <h2 class="post-title">Create New Post</h2>

        <form method="post" enctype="multipart/form-data">

            <div class="mb-3">
                <input type="text" class="form-control" asp-for="Title" placeholder="Enter title" />
            </div>

            <div class="mb-3">
                <textarea class="form-control" asp-for="postContent" placeholder="Enter your post"></textarea>
            </div>

            <div class="mb-3">
                <input type="file" class="form-control file-input" name="imageFile" />
            </div>

            <button type="submit" class="btn btn-primary btn-post">
                Post Now 🚀
            </button>

        </form>
    </div>

</body>
</html>