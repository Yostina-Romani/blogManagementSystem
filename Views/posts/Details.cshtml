@model Posts

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Post Card -->
            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5">

                    <!-- Title -->
                    <h1 class="fw-bold mb-3 text-dark">
                        @Model.Title
                    </h1>

                    <!-- Meta Info -->
                    <div class="d-flex justify-content-between text-muted small mb-4">

                        <span>
                            🕒 @Model.createAt
                        </span>

                        <span>
                            👤 @Model.User?.UserName
                        </span>

                    </div>

                    <hr />

                    <!-- Content -->
                    <p class="fs-5 lh-lg text-secondary">
                        @Model.postContent
                    </p>

                    <hr />
     <div>
         @Model.imageUrl;
     </div>
                    <!-- Footer Info -->
                    <div class="text-muted small">

                        <p class="mb-1">
                            📧 @Model.User?.UserEmail
                        </p>

                        

                    </div>

                </div>

            </div>

        </div>
    </div>

</div>