@model Posts

<style>
    body {
        background: #f4f6fb;
    }

    .delete-box {
        max-width: 450px;
        margin: 80px auto;
        background: #fff;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        text-align: center;
    }

    .delete-title {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 10px;
        color: #dc3545;
    }

    .delete-text {
        color: #666;
        margin-bottom: 25px;
        font-size: 15px;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 25px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-delete:hover {
            background: #bb2d3b;
        }

    .btn-cancel {
        display: inline-block;
        margin-left: 10px;
        padding: 10px 18px;
        border-radius: 25px;
        text-decoration: none;
        background: #6c757d;
        color: white;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            background: #5a6268;
        }

    .warning-icon {
        font-size: 40px;
        color: #dc3545;
        margin-bottom: 10px;
    }
</style>

<div class="delete-box">

    <div class="warning-icon">⚠️</div>

    <div class="delete-title">
        Delete Post
    </div>

    <div class="delete-text">
        Are you sure you want to delete this post?
        This action cannot be undone.
    </div>

    <form asp-action="DeletePost"
          asp-controller="Posts"
          method="post">

        <input type="hidden" asp-for="postsId" />

        <button type="submit" class="btn-delete">
            Yes, Delete
        </button>

        <a asp-action="Index"
           asp-controller="Home"
           class="btn-cancel">
            Cancel
        </a>

    </form>

</div>