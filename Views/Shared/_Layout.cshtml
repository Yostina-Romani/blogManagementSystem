<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlogManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BlogManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
       
    
    <div class="container">
        <main role="main" class="pb-3">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                <div class="container-fluid">

                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        Blog Management System
                    </a>

                    <!-- زرار الموبايل -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <!-- اللينكات -->
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <div class="navbar-nav ms-auto">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Create Account</a>
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            <a class="nav-link" asp-controller="posts" asp-action="post">Posts</a>
                                <a asp-action="Logout" asp-controller="Account" class="nav-link">logout</a>
                        </div>
                    </div>

                </div>
            </nav>
            @RenderBody()
        </main>
    </div>
    </header>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BlogManagementSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
